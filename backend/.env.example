# Backend Environment Variables
NODE_ENV=production
PORT=3001

# MQTT Broker
MQTT_BROKER=mqtt://mosquitto_absensi:1883
MQTT_TOPIC=double-take/matches/#

# CompreFace
COMPREFACE_URL=http://compreface-ui:80
# Real API key from server (compreface-ui exposes port 80 internally, maps to 8000 on host)
COMPREFACE_API_KEY=b410e83f-4343-4079-a98f-d43e13610846

# Database
DB_PATH=/data/attendance.db

# JWT Auth
JWT_SECRET=change_this_to_a_random_secret_string
JWT_EXPIRES_IN=8h

# Admin Credentials (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Confidence Threshold (%)
CONFIDENCE_THRESHOLD=80

# Debounce cooldown in minutes per user
DEBOUNCE_MINUTES=3
